# LiteLLM
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=your-key
CHAT_MODEL=gpt-4o-mini
FALLBACK_CHAT_MODEL=
EMBED_MODEL=text-embedding-3-large

# Native Chainlit persistence + auth (required for left sidebar thread history)
# PostgreSQL stores users, threads, messages, and feedback
DATABASE_URL=postgresql://chainlit:chainlit@postgres:5432/chainlit
CHAINLIT_AUTH_SECRET=change-me-with-a-long-random-string
CHAINLIT_INIT_DB=true

# GitHub OAuth - Create app at https://github.com/settings/developers
# Callback URL: http://localhost:8000/auth/oauth/github/callback (adjust for production)
OAUTH_GITHUB_CLIENT_ID=Iv1.abc123def456
OAUTH_GITHUB_CLIENT_SECRET=0123456789abcdef0123456789abcdef01234567

# Admin fallback authentication (optional, for local development without OAuth)
CHAINLIT_AUTH_USERNAME=admin
CHAINLIT_AUTH_PASSWORD=admin

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=grundschutz
TOP_K=5
MAX_TOP_K=5
MAX_SOURCE_LINKS=8
SCORE_THRESHOLD=0.0
MAX_TOOL_CALL_ROUNDS=12
STREAMING_ENABLED=false
STREAMING_DOUBLE_PASS=false

# Auto-ingestion in Docker Compose
INGEST_DOCLING_JSON_DIR=/data/data_docling_json_ocr
INGEST_RECREATE=false
INGEST_BATCH_SIZE=256
INGEST_MAX_BATCH_CHARS=20000

# Optional system prompt
SYSTEM_PROMPT_PATH=../../system.md
DATA_RAW_DIR=../../data/data_raw
GRUNDSCHUTZ_SOURCE_PDF=IT_Grundschutz_Kompendium_Edition2023.pdf
DATA_PREPROCESSED_DIR=/data/data_preprocessed
CITATION_MAP_PATH=./citation_map.json
STARTER_QUESTIONS=Was ist der Unterschied zwischen Prozess- und Systembausteinen?||Welche Schritte umfasst die Basis-Absicherung nach BSI-Standard 200-2?||Wie müssen Passwörter bei der Authentisierung am Webserver gesichert werden?

# Chat history persistence + export
CHAT_DB_PATH=./.chainlit/chat_history.sqlite3
CHAT_EXPORT_DIR=./.files/chat_exports
